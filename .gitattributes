# Rainmeter on Windows expects CRLF for .ini and .inc files
*.ini     text eol=crlf
*.inc     text eol=crlf
*.lua     text eol=lf
*.ps1     text eol=crlf
*.cmd     text eol=crlf
*.txt     text eol=crlf
*.md      text eol=crlf

# Binary/auto-generated
.gitignore    text eol=crlf
.gitattributes text eol=crlf
