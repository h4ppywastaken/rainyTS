[StyleChannel]
FontFace=#FontName#
FontSize=#FontSize#
FontColor=#ColorChannel#
StringStyle=Bold
AntiAlias=1
ClipString=2
W=(#SkinWidth# - #PaddingX# * 2)

[StyleName]
FontFace=#FontName#
FontSize=#FontSize#
FontColor=#ColorName#
AntiAlias=1
ClipString=1
W=(#SkinWidth# - #PaddingX# - #UserNameOffset# - 5)
